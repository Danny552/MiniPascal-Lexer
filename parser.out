Grammar

Rule 0     S' -> program
Rule 1     program -> PROGRAM ID SEMICOLON uses_clause declaration_sections compound_stmt DOT
Rule 2     uses_clause -> USES id_list SEMICOLON
Rule 3     uses_clause -> empty
Rule 4     id_list -> ID
Rule 5     id_list -> id_list COMMA ID
Rule 6     declaration_sections -> declaration_sections section
Rule 7     declaration_sections -> empty
Rule 8     section -> const_section
Rule 9     section -> type_section
Rule 10    section -> var_section
Rule 11    section -> procedure_declaration
Rule 12    section -> function_declaration
Rule 13    const_section -> CONST const_list
Rule 14    const_list -> const_list ID EQUALS expression SEMICOLON
Rule 15    const_list -> ID EQUALS expression SEMICOLON
Rule 16    type_section -> TYPE type_list
Rule 17    type_section -> empty
Rule 18    type_list -> type_list ID EQUALS type_specifier SEMICOLON
Rule 19    type_list -> ID EQUALS type_specifier SEMICOLON
Rule 20    var_section -> VAR var_list
Rule 21    var_list -> var_list id_list COLON type_specifier SEMICOLON
Rule 22    var_list -> id_list COLON type_specifier SEMICOLON
Rule 23    type_specifier -> ID
Rule 24    type_specifier -> STRING LBRACKET NUMBER RBRACKET
Rule 25    type_specifier -> NUMBER DOT DOT NUMBER
Rule 26    procedure_declaration -> PROCEDURE ID LPAREN args RPAREN SEMICOLON compound_stmt SEMICOLON
Rule 27    function_declaration -> FUNCTION ID LPAREN args RPAREN COLON type_specifier SEMICOLON compound_stmt SEMICOLON
Rule 28    compound_stmt -> BEGIN statement_list END
Rule 29    statement_list -> statement_list statement
Rule 30    statement_list -> statement
Rule 31    if_stmt -> IF LPAREN expression RPAREN THEN statement
Rule 32    if_stmt -> IF LPAREN expression RPAREN THEN statement ELSE statement
Rule 33    for_stmt -> FOR ID ASSIGN expression TO expression DO statement
Rule 34    statement -> call_stmt SEMICOLON
Rule 35    statement -> assignment_stmt SEMICOLON
Rule 36    statement -> compound_stmt
Rule 37    statement -> if_stmt
Rule 38    statement -> for_stmt
Rule 39    statement -> empty
Rule 40    call_stmt -> ID LPAREN args RPAREN
Rule 41    call_stmt -> ID
Rule 42    args -> expression_list
Rule 43    args -> empty
Rule 44    expression_list -> expression_list COMMA expression
Rule 45    expression_list -> expression
Rule 46    assignment_stmt -> ID ASSIGN expression
Rule 47    expression_formatted -> expression COLON type_specifier
Rule 48    expression -> term
Rule 49    expression -> expression PLUS term
Rule 50    expression -> expression MINUS term
Rule 51    expression -> expression GREATER term
Rule 52    expression -> expression LESS term
Rule 53    expression -> expression GREATEREQUAL term
Rule 54    expression -> expression LESSEQUAL term
Rule 55    expression -> expression NOTEQUAL term
Rule 56    expression -> expression_formatted
Rule 57    factor -> NUMBER
Rule 58    factor -> STRING
Rule 59    factor -> call_stmt
Rule 60    factor -> LPAREN expression RPAREN
Rule 61    term -> factor
Rule 62    term -> term TIMES factor
Rule 63    term -> term DIVIDE factor
Rule 64    empty -> <empty>

